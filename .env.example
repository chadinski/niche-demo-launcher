NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=0
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
FIRECRAWL_API_KEY=

# Public default design tokens used by foundational design helpers.
NEXT_PUBLIC_DEFAULT_PRIMARY_COLOR=#2B5E8C
NEXT_PUBLIC_DEFAULT_SECONDARY_COLOR=#F4A261

# Centralized stage-based model routing. Keep real API keys server-side only.
EXTRACTION_MODEL=gemini-2.5-flash-lite
CREATIVE_MODEL=gemini-2.5-pro
DESIGN_SYSTEM_MODEL=gemini-2.5-pro
PLANNER_MODEL=gemini-2.5-pro
PAGE_CONTRACT_MODEL=gemini-2.5-pro
SECTION_MODEL=gemini-2.5-pro
QA_MODEL=gemini-2.5-flash
VISUAL_QA_MODEL=gemini-2.5-flash
OUTREACH_MODEL=gemini-2.5-flash
INSPIRATION_MODEL=gemini-2.5-flash
VISION_MODEL=gemini-2.5-flash
FALLBACK_MODEL=gemini-2.5-flash-lite
OPENAI_MODEL=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-3.1-flash-lite-preview,gemini-flash-lite-latest,gemini-2.5-flash
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO_PREFIX=niche-demo
VERCEL_TOKEN=
VERCEL_TEAM_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=

# Public-beta access controls. Managed deployment remains off unless explicitly enabled,
# and only listed accounts can use shared deployment credentials.
AUTOMATED_DEPLOYMENT_ENABLED=0
DEPLOYMENT_APPROVED_EMAILS=
ADMIN_EMAILS=

# Optional provider-neutral observability integration seams.
ERROR_REPORTING_DSN=
ANALYTICS_ENDPOINT=

# Optional per-operation cost estimates used in the Usage ledger.
COST_ESTIMATE_SCREENSHOT_EXTRACTION_USD=0.01
COST_ESTIMATE_LEAD_SEARCH_USD=0.02
COST_ESTIMATE_FAST_GENERATION_USD=0.12
COST_ESTIMATE_PREMIUM_GENERATION_USD=0.45
COST_ESTIMATE_REGENERATION_USD=0.05
COST_ESTIMATE_OUTREACH_GENERATION_USD=0.01
COST_ESTIMATE_DEPLOYMENT_USD=0.001

# Optional rendered QA. Requires Playwright to be installed in the runtime.
SERAPHIM_RENDER_QA=0
